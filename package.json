{
  "name": "radar-ofertas",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "check": "tsx --env-file=.env src/scripts/preflight.ts",
    "setup": "tsx --env-file=.env src/scripts/preflight.ts --guide",
    "up": "tsx --env-file=.env src/scripts/up.ts",
    "predev": "tsx --env-file=.env src/scripts/preflight.ts --profile=collector",
    "dev": "tsx watch --env-file=.env src/app.ts",
    "prescheduler": "tsx --env-file=.env src/scripts/preflight.ts --profile=scheduler",
    "scheduler": "tsx watch --env-file=.env src/scheduler.ts",
    "preworker": "tsx --env-file=.env src/scripts/preflight.ts --profile=worker",
    "worker": "tsx watch --env-file=.env src/worker.ts",
    "preworker:telegram": "tsx --env-file=.env src/scripts/preflight.ts --profile=worker-telegram",
    "worker:telegram": "tsx watch --env-file=.env src/worker-telegram.ts",
    "start": "node --env-file=.env build/app.js",
    "start:worker": "node --env-file=.env build/worker.js",
    "start:worker:telegram": "node --env-file=.env build/worker-telegram.js",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma": "prisma generate",
    "ml:login": "tsx --env-file=.env src/ml-login.ts",
    "wa:channel": "tsx --env-file=.env src/wa-channel.ts",
    "wa:login": "tsx --env-file=.env src/wa-login.ts",
    "premanager": "tsx --env-file=.env src/scripts/preflight.ts --profile=manager",
    "manager": "tsx watch --env-file=.env manager/server.ts",
    "start:manager": "tsx --env-file=.env manager/server.ts",
    "e2e:test": "tsx --env-file=.env src/run-e2e-test.ts",
    "test": "tsx --import ./src/test/preload.ts src/test/run-tests.ts",
    "lint": "eslint \"src/**/*.ts\" \"manager/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"manager/**/*.ts\" --fix",
    "format": "prettier --write src manager",
    "format:check": "prettier --check src manager",
    "postinstall": "prisma generate && playwright install chromium"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.8.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.6",
    "prisma": "^6.19.0",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@prisma/client": "^6.19.0",
    "baileys": "github:alesdi/Baileys#fix/newsletter-media-upload-path",
    "bullmq": "^5.66.4",
    "cheerio": "^1.1.2",
    "pino": "^10.3.1",
    "playwright": "^1.52.0",
    "qrcode-terminal": "^0.12.0",
    "zod": "^4.4.3"
  }
}
