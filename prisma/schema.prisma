generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model Offer {
  id             String    @id @default(cuid())
  mercadoLivreId String    @unique @map("mercado_livre_id")
  title          String
  price          Decimal   @db.Decimal(12, 2)
  oldPrice       Decimal?  @map("old_price") @db.Decimal(12, 2)
  discount       Int?
  image          String?
  permalink      String?
  affiliateLink  String?   @map("affiliate_link")
  rating         Float?
  soldQuantity   Int?      @map("sold_quantity")
  salesRank      String?   @map("sales_rank")
  seller         String?
  officialStore  Boolean   @default(false) @map("official_store")
  bestSeller     Boolean   @default(false) @map("best_seller")
  score          Int       @default(0)
  sentAt         DateTime? @map("sent_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("offers")
}
